{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ does not have any app versions." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@にはアプリバージョンがありません。"
          }
        }
      }
    },
    "%@ error %@." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ error %2$@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
