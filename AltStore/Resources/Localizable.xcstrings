    },
    "AltStore can only install marketplace apps that have been notarized by Apple." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStoreはAppleによって公証済みのマーケットプレイスアプリのみをインストールできます。"
          }
        }
      }
    },
    "AltStore could not determine this device's UDID." : {
      "localizations" : {
