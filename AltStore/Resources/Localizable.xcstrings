    },
    "Non-developer Apple IDs are limited to 3 active apps and app extensions, and “%@” contains %@ %@. Please choose an app to deactivate." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Non-developer Apple IDs are limited to 3 active apps and app extensions, and “%1$@” contains %2$@ %3$@. Please choose an app to deactivate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非開発者用Apple IDでは、アクティブなアプリとアプリ拡張機能は3つまでに制限され、「%1$@」は%2$@と%3$@を含んでいます。無効にするアプリを1つ選んでください。"
          }
        }
      }
    },
    "Non-developer Apple IDs are limited to 3 active apps and app extensions." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非開発者用Apple IDでは、アクティブなアプリとアプリ拡張機能は3つまでに制限されます。"
          }
        }
      }
    },
    "Non-developer Apple IDs are limited to 3 active apps and app extensions. Please choose an app to deactivate." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非開発者用Apple IDでは、アクティブなアプリとアプリ拡張機能は3つまでに制限されます。無効にするアプリを1つ選んでください。"
          }
        }
      }
    },
    "Non-developer Apple IDs are limited to 3 active apps. Please choose an app to deactivate." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非開発者用Apple IDでは、アクティブなアプリは3つまでに制限されます。無効にするアプリを1つ選んでください。"
          }
        }
      }
    },
    "Non-developer Apple IDs are limited to 3 apps and app extensions. Inactive apps don't count towards your total, but cannot be opened until activated." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非開発者用Apple IDでは、アプリとアプリ拡張機能は3つまでに制限されます。非アクティブなアプリは合計数にはカウントされませんが、アクティブ化されるまで開くことはできません。"
          }
        }
      }
    },
    "Non-developer Apple IDs are limited to 3 apps. Inactive apps are backed up and uninstalled so they don't count towards your total, but will be reinstalled with all their data when activated again." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非開発者用Apple IDでは、アプリは3つまでに制限されます。非アクティブなアプリはバックアップされアンインストールされるため、合計数にはカウントされませんが、再度アクティブ化すると、すべてのデータと共に再インストールされます。"
          }
        }
      }
    },
    "Non-developer Apple IDs are limited to creating 10 App IDs per week." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非開発者用Apple IDでは、1週間に作成できるアプリIDは10個までです。"
