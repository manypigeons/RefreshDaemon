    },
    "What are sources?" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ソースとは何ですか？"
          }
        }
      }
    },
    "While AltStore 2.0 is in beta, you may choose to ignore this warning at your own risk until the source is updated." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStore 2.0はベータ版ですが、ソースがアップデートされるまでは自己責任でこの警告を無視することもできます。"
          }
        }
      }
    },
    "wired AltServer" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有線AltServer"
          }
        }
      }
    },
    "Would you like to add the source “%@”?" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ソース「%@」を追加しますか？"
          }
        }
      }
    },
    "Would you like to download the last version compatible with this device instead?" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "代わりに、このデバイスと互換性のある最新バージョンをダウンロードしますか？"
          }
        }
      }
    },
    "Would you like to remove this app's extensions so they don't count towards your limit?" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリの拡張機能を削除して、制限にカウントされないようにしますか？"
          }
        }
      }
    },
    "You are not signed in." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サインインしていません。"
          }
        }
      }
    },
    "You can register another App ID in %@." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@後に別のアプリIDを登録できます。"
          }
        }
      }
    },
    "You cannot register more than 10 App IDs within a 7 day period." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "7日間で登録できるアプリIDは10件までです。"
          }
        }
      }
    },
    "You must add this source before installing apps from it.\n\n“%@” will begin downloading once it has been added." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このソースからアプリをインストールする前に、このソースを追加する必要があります。\n\n「%@」は追加されるとすぐにダウンロードを開始します。"
          }
        }
      }
    },
    "You must also delete it from the home screen to fully uninstall the app." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリを完全にアンインストールするには、ホーム画面からも削除する必要があります。"
          }
        }
      }
    },
    "You will no longer be able to install or refresh any apps that require pledges." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "支援を必要とするアプリのインストールや更新ができなくなります。"
          }
        }
      }
    },
    "You will no longer be able to install or refresh apps once you sign out." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サインアウトすると、アプリのインストールや更新ができなくなります。"
          }
        }
      }
    },
    "You will no longer be able to install or update any apps that require pledges." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "支援を必要とするアプリのインストールやアップデートができなくなります。"
          }
        }
      }
    },
    "You're signed into Patreon but haven't connected your account with AltStore.\n\nPlease connect your account to download Patreon-exclusive apps." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patreonにはサインインしていますが、アカウントがAltStoreと連携されていません。\n\nPatreon限定アプリをダウンロードするには、アカウントを連携してください。"
          }
        }
      }
    },
    "You've received 1 month of free access to our “Early Adopter” Patreon tier!\n\nMake sure you have joined our Patreon campaign as a free member and connected your Patreon account in Settings." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「アーリーアダプター」Patreonティアの1か月間無料アクセス権を獲得しました！\n\n無料メンバーとしてPatreonキャンペーンに参加し、「設定」でPatreonアカウントを連携していることをご確認ください。"
          }
        }
      }
    },
    "Your Apple ID has no developer teams." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたのApple IDには開発者チームがありません。"
          }
        }
      }
    },
    "your device's iOS version" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お使いのデバイスのiOSバージョン"
          }
        }
      }
    },
    "Your pledge is no longer active. Please renew it to continue using %@ normally." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "支援は現在無効になっています。%@を通常どおり利用するには、更新してください。"
          }
