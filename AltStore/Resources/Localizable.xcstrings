    },
    "AltStore Expiring Soon" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStoreの期限がまもなく切れます"
          }
        }
      }
    },
    "AltStore News" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStoreニュース"
          }
        }
      }
    },
    "AltStore was denied permission to launch %@." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStoreは%@を起動する権限を拒否されました。"
          }
        }
      }
    },
    "AltStore was unable to use an existing signing certificate, so it had to create a new one. This will cause any apps installed with an existing certificate to expire — including AltStore.\n\nTo prevent AltStore from expiring early, please refresh the app now. AltStore will quit once refreshing is complete." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStoreは既存の署名証明書を使用できなかったため、新しい証明書を作成する必要がありました。これにより、既存の証明書でインストールされたアプリ（AltStoreを含む）はすべて期限切れとなります。\n\nAltStoreの早期期限切れを防ぐため、今すぐアプリを更新してください。更新が完了するとAltStoreは終了します。"
          }
        }
      }
    },
    "AltStore will expire in 24 hours. Open the app and refresh it to prevent it from expiring." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStoreは24時間後に期限切れになります。期限切れを防ぐにはアプリを開き、更新してください。"
          }
        }
      }
    },
    "AltStore's shared app group could not be accessed." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AltStoreの共有アプリグループにアクセスできませんでした。"
