{
  "sourceLanguage" : "en",
  "strings" : {
    "“%@” Blocked" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」をブロックしました"
          }
        }
      }
    },
    "“%@” could not be added to AltStore." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」をAltStoreに追加できませんでした。"
          }
        }
      }
    },
    "“%@” will be automatically given these permissions once installed." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」はインストール後に、これらの権限が自動的に付与されます。"
